-- ================= ESP SYSTEM =================


local ESPEnabled = false
local ESPObjects = getgenv().ESP_OBJECTS

local ESPSettings = {
    Highlight = true,
    Name = true,
    Skeleton = false
}

-- REMOVE ESP
local function removeESP(p)
    if ESPObjects[p] then
        for _,obj in pairs(ESPObjects[p]) do
            if typeof(obj) == "table" then
                for _,v in pairs(obj) do
                    if v and v.Destroy then v:Destroy() end
                end
            else
                if obj and obj.Destroy then obj:Destroy() end
            end
        end
        ESPObjects[p] = nil
    end
end


getgenv().ESP_CLEANUP = function()
    for p,_ in pairs(ESPObjects) do
        removeESP(p)
    end
end

-- REFRESH 
local function refreshESP()
    for p,_ in pairs(ESPObjects) do
        removeESP(p)
    end
end

-- CREATE ESP
local function createESP(p)
    if ESPObjects[p] then return end

    local char = p.Character or p.CharacterAdded:Wait()
    if not char then return end

    ESPObjects[p] = {}

    -- HIGHLIGHT
    if ESPSettings.Highlight then
        local h = Instance.new("Highlight")
        h.FillColor = Color3.fromRGB(255,0,0)
        h.OutlineColor = Color3.fromRGB(255,255,255)
        h.FillTransparency = 0.5
        h.Parent = char

        ESPObjects[p].Highlight = h
    end

    -- NAME + DISTANCE
    if ESPSettings.Name then
        local head = char:FindFirstChild("Head")
        if head then
            local bb = Instance.new("BillboardGui")
            bb.Size = UDim2.new(0,200,0,50)
            bb.AlwaysOnTop = true
            bb.StudsOffset = Vector3.new(0,3,0)
            bb.Parent = head

            local txt = Instance.new("TextLabel")
            txt.Size = UDim2.new(1,0,1,0)
            txt.BackgroundTransparency = 1
            txt.TextColor3 = Color3.new(1,1,1)
            txt.TextStrokeTransparency = 0
            txt.TextScaled = true
            txt.Parent = bb

            ESPObjects[p].Billboard = bb
            ESPObjects[p].Text = txt
        end
    end

    -- SKELETON
    if ESPSettings.Skeleton then
        local pairsList = {
            {"Head","UpperTorso"},
            {"UpperTorso","LowerTorso"},
            {"UpperTorso","LeftUpperArm"},
            {"UpperTorso","RightUpperArm"},
            {"LowerTorso","LeftUpperLeg"},
            {"LowerTorso","RightUpperLeg"}
        }

        ESPObjects[p].Skeleton = {}

        for _,pair in ipairs(pairsList) do
            local p1 = char:FindFirstChild(pair[1])
            local p2 = char:FindFirstChild(pair[2])

            if p1 and p2 then
                local a0 = Instance.new("Attachment", p1)
                local a1 = Instance.new("Attachment", p2)

                local beam = Instance.new("Beam")
                beam.Attachment0 = a0
                beam.Attachment1 = a1
                beam.Width0 = 0.05
                beam.Width1 = 0.05
                beam.Color = ColorSequence.new(Color3.new(1,1,1))
                beam.Parent = p1

                table.insert(ESPObjects[p].Skeleton, beam)
                table.insert(ESPObjects[p].Skeleton, a0)
                table.insert(ESPObjects[p].Skeleton, a1)
            end
        end
    end
end

