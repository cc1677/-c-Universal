local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Color = Color3.fromRGB(255, 255, 255)
FOVCircle.Transparency = 1
FOVCircle.Filled = false

local function GetClosestPlayer()
    local Target, ClosestDist = nil, getgenv().FOVRadius
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Team ~= LocalPlayer.Team and p.Character and p.Character:FindFirstChild("Head") then
            local pos, onScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if onScreen then
                local mouseLocation = UIS:GetMouseLocation()
                local distToMouse = (Vector2.new(pos.X, pos.Y) - mouseLocation).Magnitude
                
                if distToMouse < ClosestDist then
                    local worldDist = (p.Character.Head.Position - myRoot.Position).Magnitude
                    if worldDist <= getgenv().MaxDist then
                        ClosestDist = distToMouse
                        Target = p
                    end
                end
            end
        end
    end
    return Target
end

RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = getgenv().FOVVisible
    FOVCircle.Radius = getgenv().FOVRadius
    FOVCircle.Position = UIS:GetMouseLocation()

    if getgenv().AimbotEnabled then
        local T = GetClosestPlayer()
        if T and T.Character and T.Character:FindFirstChild("Head") then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, T.Character.Head.Position), getgenv().Sensitivity)
        end
    end
end)


local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if getgenv().SilentAimEnabled and not checkcaller() then
        if method == "Raycast" then
            local T = GetClosestPlayer()
            if T and T.Character and T.Character:FindFirstChild("Head") then
                
                args[2] = (T.Character.Head.Position - args[1]).Unit * 1000
                return oldNamecall(self, unpack(args))
            end
        elseif method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRay" then
            local T = GetClosestPlayer()
            if T and T.Character and T.Character:FindFirstChild("Head") then
                
                args[1] = Ray.new(args[1].Origin, (T.Character.Head.Position - args[1].Origin).Unit * 1000)
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

mt.__index = newcclosure(function(self, index)
    if getgenv().SilentAimEnabled and not checkcaller() then
        if self == Mouse and (index == "Hit" or index == "Target") then
            local T = GetClosestPlayer()
            if T and T.Character and T.Character:FindFirstChild("Head") then
                return (index == "Hit" and T.Character.Head.CFrame or T.Character.Head)
            end
        
        elseif index == "Instance" and self:IsA("RaycastResult") then
            local T = GetClosestPlayer()
            if T and T.Character and T.Character:FindFirstChild("Head") then
                return T.Character.Head
            end
        elseif index == "Position" and self:IsA("RaycastResult") then
            local T = GetClosestPlayer()
            if T and T.Character and T.Character:FindFirstChild("Head") then
                return T.Character.Head.Position
            end
        end
    end
    return oldIndex(self, index)
end)
setreadonly(mt, true)

