local ESPEnabled = false
local ESPObjects = getgenv().ESP_OBJECTS
local ESPSettings = { Highlight = true, Name = true, Skeleton = false }

local function removeESP(p)
    if ESPObjects[p] then
        for _,obj in pairs(ESPObjects[p]) do
            if typeof(obj) == "table" then for _,v in pairs(obj) do if v and v.Destroy then v:Destroy() end end
            else if obj and obj.Destroy then obj:Destroy() end end
        end
        ESPObjects[p] = nil
    end
end

getgenv().ESP_CLEANUP = function() for p,_ in pairs(ESPObjects) do removeESP(p) end end

local function createESP(p)
    if ESPObjects[p] then return end
    local char = p.Character or p.CharacterAdded:Wait()
    ESPObjects[p] = {}
    if ESPSettings.Highlight then
        local h = Instance.new("Highlight", char)
        h.FillColor = Color3.fromRGB(255,0,0)
        ESPObjects[p].Highlight = h
    end
    if ESPSettings.Name then
        local head = char:FindFirstChild("Head")
