local Lighting = game:GetService("Lighting")
local Terrain = workspace.Terrain

local originalSettings = {
    GlobalShadows = Lighting.GlobalShadows,
    Technology = Lighting.Technology,
    WaterWaveSize = Terrain.WaterWaveSize,
    WaterWaveSpeed = Terrain.WaterWaveSpeed,
    WaterReflectance = Terrain.WaterReflectance,
    PostProcesses = {},
    Parts = {},
    PartShadows = {},
    Textures = {},
    Particles = {},
    Meshes = {},
}

for _, effect in ipairs(Lighting:GetChildren()) do
    if effect:IsA("PostProcessEffect") then
        originalSettings.PostProcesses[effect] = effect.Enabled
    end
end

local function SetPotatoMode(state)
    Lighting.GlobalShadows = not state and originalSettings.GlobalShadows or false
    Lighting.Technology = state and Enum.Technology.Compatibility or originalSettings.Technology

    for effect, enabled in pairs(originalSettings.PostProcesses) do
        effect.Enabled = not state and enabled or false
    end

    Terrain.WaterWaveSize = state and 0 or originalSettings.WaterWaveSize
    Terrain.WaterWaveSpeed = state and 0 or originalSettings.WaterWaveSpeed
    Terrain.WaterReflectance = state and 0 or originalSettings.WaterReflectance

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Decal") or obj:IsA("Texture") then
            if originalSettings.Textures[obj] == nil then
                originalSettings.Textures[obj] = obj.Transparency
            end
            obj.Transparency = state and 1 or originalSettings.Textures[obj]

        elseif obj:IsA("BasePart") then
            if originalSettings.Parts[obj] == nil then
                originalSettings.Parts[obj] = obj.Material
                originalSettings.PartShadows[obj] = obj.CastShadow
            end
            obj.Material = state and Enum.Material.SmoothPlastic or originalSettings.Parts[obj]
            obj.CastShadow = not state and originalSettings.PartShadows[obj] or false

        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
            if originalSettings.Particles[obj] == nil then
                originalSettings.Particles[obj] = obj.Enabled
            end
            obj.Enabled = not state and originalSettings.Particles[obj] or false

        elseif obj:IsA("MeshPart") then
            if originalSettings.Meshes[obj] == nil then
                originalSettings.Meshes[obj] = obj.RenderFidelity
            end
            obj.RenderFidelity = state and Enum.RenderFidelity.Performance or originalSettings.Meshes[obj]
        end
    end
end

